# ============================================================
# EmergiQR — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# ============================================================

# Supabase — obtenés estos valores en:
# https://supabase.com/dashboard > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública de la app (usada para generar el QR)
# En local: http://localhost:3000
# En producción: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
